#!/usr/bin/env python3
"""
A tmux clipboard forwarder. Pair this with tmux-receiver.
See protocol.py for wire format and response codes.
"""

import os
import subprocess
import sys
import socket
import struct
import zlib

from protocol import DtTmfConfig, DtTmfResponse

CONFIG = DtTmfConfig()


def notify(msg, duration=4000):
    """Print a message to the tmux status bar"""
    if os.environ.get("TMUX"):
        subprocess.run(
            ["tmux", "display-message", "-d", str(duration), msg], check=False
        )
    else:
        print(msg, file=sys.stderr)


def send_clipboard(data):
    header = struct.pack(
        CONFIG.STRF, CONFIG.MAGIC, CONFIG.VERS, len(data), zlib.crc32(data) & 0xFFFFFFFF
    )
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
            sock.settimeout(2)
            sock.connect(("localhost", CONFIG.PORT))
            sock.sendall(header + data)
            sock.shutdown(socket.SHUT_WR)

            resp = sock.recv(1)
            if resp and resp[0] == DtTmfResponse.REJECTED:
                notify("tmux-forwarder: Receiver rejected payload")
                sys.exit(1)
            elif resp and resp[0] == DtTmfResponse.CLIPERR:
                notify("tmux-forwarder: Clipboard write failed")
                sys.exit(1)
            else:
                notify(f"tmux-forwarder: Transferred {len(data)} bytes", duration=2000)

    except socket.timeout:
        notify("tmux-forwarder: Connection timeout. Is tmux-receiver running?")
        sys.exit(1)

    except ConnectionRefusedError:
        notify("tmux-forwarder: Connection refused. Is RemoteForward tunnel open?")
        sys.exit(1)

    except Exception as e:
        notify(f"tmux-forwarder: Error: {e}")
        sys.exit(1)


if __name__ == "__main__":
    """Entry point for tmux to invoke via binding"""

    data = sys.stdin.buffer.read()

    if not data:
        sys.exit(0)
    if len(data) > CONFIG.PMAX:
        notify(f"tmux-forwarder: Payload {len(data)} too large")
        sys.exit(1)

    send_clipboard(data)
