#!/usr/bin/env python3
"""
A tmux clipboard forwarder. Pair this with tmux-receiver.

Wire format: [4U8:TMXC][1U8:Version][U32:Length][U32:CRC32][xU8:Payload]
"""
import os
import subprocess
import sys
import socket
import struct
import zlib

PORT        = 50024
MAGIC       = b'TMXC'
VERSION     = 1
HEADER      = '!4sBII'  # magic, version, length, crc32
MAX_PAYLOAD = 128 * 1024

def error(msg):
    print(msg, file=sys.stderr)
    if os.environ.get('TMUX'):
        subprocess.run(['tmux', 'display-message', '-d', '4000', msg], check=False)

def send_clipboard(data):
    header = struct.pack(HEADER, MAGIC, VERSION, len(data), zlib.crc32(data) & 0xFFFFFFFF)
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
            sock.settimeout(2)
            sock.connect(('localhost', PORT))
            sock.sendall(header + data)

    except socket.timeout:
        error("tmux-forwarder: Connection timeout. Is tmux-receiver running?")
        sys.exit(1)

    except ConnectionRefusedError:
        error("tmux-forwarder: Connection refused. Is RemoteForward tunnel open?")
        sys.exit(1)

    except Exception as e:
        error(f"tmux-forwarder: Error: {e}")
        sys.exit(1)

if __name__ == '__main__':
    data = sys.stdin.buffer.read()
    if not data:
        sys.exit(0)
    if len(data) > MAX_PAYLOAD:
        error(f"tmux-forwarder: Payload too large ({len(data)} > {MAX_PAYLOAD})")
        sys.exit(1)
    send_clipboard(data)
