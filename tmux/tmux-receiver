#!/usr/bin/env python3
"""
A tmux clipboard receiver.

Pairs with tmux-forwarder running on the remote host. Requires an SSH
RemoteForward. See protocol.py for wire format and response codes.
"""

import os
import socket
import struct
import subprocess
import sys
import zlib

from protocol import DtTmfConfig, DtTmfResponse

CONFIG = DtTmfConfig()


def get_clipboard():
    if sys.platform == "darwin":
        return ["pbcopy"]
    if os.environ.get("WAYLAND_DISPLAY"):
        return ["wl-copy"]
    if os.environ.get("DISPLAY"):
        return ["xclip", "-selection", "clipboard"]
    print("tmux-receiver: No clipboard backend found", file=sys.stderr)
    sys.exit(1)


def loop(cmd):
    """Blocking receiver awaing data from tmux-forwarder"""

    server_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server_sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)

    try:
        server_sock.bind(("localhost", CONFIG.PORT))
        server_sock.listen(1)
        print(
            f"tmux-receiver: Listening on localhost:{CONFIG.PORT}...\n"
            "Press Ctrl+C to stop\n",
        )

        while True:
            client_sock, _ = server_sock.accept()
            try:
                status = DtTmfResponse.ACCEPTED
                # Wrap the socket in a file-like object
                with client_sock.makefile("rb") as f:
                    # Decode the input data
                    raw = f.read(CONFIG.hsize)
                    if len(raw) != CONFIG.hsize:
                        print("ERR: Incomplete header", file=sys.stderr)
                        status = DtTmfResponse.REJECTED
                    else:
                        # Header is good, so unpack the rest
                        magic, version, length, checksum = struct.unpack(
                            CONFIG.STRF, raw
                        )

                        if magic != CONFIG.MAGIC:
                            print("ERR: Invalid magic bytes", file=sys.stderr)
                            status = DtTmfResponse.REJECTED
                        elif version != CONFIG.VERS:
                            print(
                                f"ERR: Unsupported version {version}", file=sys.stderr
                            )
                            status = DtTmfResponse.REJECTED
                        elif length > CONFIG.PMAX:
                            print(
                                f"ERR: Payload {length} too large",
                                file=sys.stderr,
                            )
                            status = DtTmfResponse.REJECTED
                        else:
                            data = f.read(length)

                if status == DtTmfResponse.ACCEPTED:
                    if len(data) != length:
                        print(
                            f"ERR: Incomplete payload; got {len(data)} of {length} bytes",
                            file=sys.stderr,
                        )
                        status = DtTmfResponse.REJECTED
                    elif (zlib.crc32(data) & 0xFFFFFFFF) != checksum:
                        print("ERR: Checksum mismatch", file=sys.stderr)
                        status = DtTmfResponse.REJECTED
                    else:
                        result = subprocess.run(cmd, input=data, check=False)
                        if result.returncode != 0:
                            print(
                                f"ERR: Clipboard command failed {result.returncode}",
                                file=sys.stderr,
                            )
                            status = DtTmfResponse.CLIPERR
                        else:
                            print(f"OKAY: {length}")
                            sys.stdout.flush()

                client_sock.sendall(bytes([status]))

            except Exception as e:
                print(f"Error handling connection: {e}", file=sys.stderr)
            finally:
                client_sock.close()

    except KeyboardInterrupt:
        print("\nShutting down...")
    except OSError as e:
        print(f"Error binding to port {CONFIG.PORT}: {e}", file=sys.stderr)
        print("Is another instance already running?", file=sys.stderr)
        sys.exit(1)
    finally:
        server_sock.close()

if __name__ == "__main__":
    cmd = get_clipboard()
    loop(cmd)
