# Example devtools config for zsh

# Preferences
export DTC_CLEAN_HISTORY=1
export DTC_SHARE_HISTORY=0
export DTC_RUN_LOGIN=1
export DTC_HISTSIZE=1000
export DTC_PREFER_HOMEBREW=1

# These aren't used on MacOS
unset DTC_XILINX_LICENSE_PATH
unset DTC_XILINX_ROOT
unset DTC_XILINX_VERSION

# Source the tools
source ${HOME}/devtools/shell/develop.zsh

# Then accept everything in the default my.sh
source ${DTC_EXISTS}/shell/my.sh
