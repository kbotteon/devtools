# This .gitconfig can be included in your global configuration file.
# You can override any of these settings after the include.
#
# [include]
#     path = /path/to/devtools/git/gitconfig

[alias]
    trail = log --oneline --decorate --stat --graph
    last = show --stat --patch --format=%B

[core]
    autocrlf = input
    editor = vim

[init]
    defaultBranch = devel

[pull]
    ff = only
    rebase = false

[status]
    submoduleSummary = true

[submodule]
    recurse = true
